{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rainy.dev/schemas/capability-lock.schema.json",
  "title": "Rainy Capability Lock",
  "type": "object",
  "required": ["lockfileVersion", "project", "rainy", "capabilities"],
  "properties": {
    "lockfileVersion": { "const": 1 },
    "project": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" }
      }
    },
    "rainy": {
      "type": "object",
      "required": ["version"],
      "properties": {
        "version": { "type": "string" }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["version", "pack", "installedAt", "artifacts"],
        "properties": {
          "version": { "type": "string" },
          "provider": { "type": ["string", "null"] },
          "pack": { "type": "string" },
          "source": { "type": "string" },
          "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "installedAt": { "type": "string", "format": "date-time" },
          "artifacts": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "skills": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
