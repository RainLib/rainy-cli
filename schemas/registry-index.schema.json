{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rainy.dev/schemas/registry-index.schema.json",
  "title": "Rainy HTTP Registry Index",
  "type": "object",
  "required": ["protocolVersion", "packs"],
  "properties": {
    "protocolVersion": { "const": "rainy.registry.v1" },
    "packs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "version", "baseUrl", "files", "digests"],
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" },
          "baseUrl": { "type": "string" },
          "files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "digests": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "pattern": "^[A-Fa-f0-9]{64}$"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
