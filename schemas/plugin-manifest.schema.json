{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rainy.dev/schemas/plugin-manifest.schema.json",
  "title": "Rainy Plugin Manifest",
  "type": "object",
  "required": ["protocolVersion", "name", "version", "permissions"],
  "properties": {
    "protocolVersion": { "const": "rainy.plugin.v1" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "inputSchema": { "type": "string" },
          "runtime": { "enum": ["wasm"] },
          "wasm": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "permissions": {
      "type": "object",
      "properties": {
        "fs": {
          "type": "object",
          "properties": {
            "read": {
              "type": "array",
              "items": { "type": "string" }
            },
            "write": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": true
        },
        "network": {
          "type": ["string", "array"]
        },
        "secrets": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "adapter": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "enum": ["http"] },
        "url": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
