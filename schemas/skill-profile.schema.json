{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rainy.dev/schemas/skill-profile.schema.json",
  "title": "Rainy Skill Profile",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "profile",
    "scope",
    "language",
    "targets",
    "packages",
    "policy"
  ],
  "properties": {
    "apiVersion": { "const": "rainy.dev/v1" },
    "kind": { "const": "SkillProfile" },
    "profile": { "enum": ["rainy", "comet"] },
    "scope": { "const": "project" },
    "language": { "enum": ["en", "zh"] },
    "targets": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "codex",
          "claude",
          "cursor",
          "github-copilot",
          "gemini",
          "opencode"
        ]
      }
    },
    "packages": {
      "type": "object",
      "properties": {
        "comet": {
          "type": "string",
          "pattern": "^@rpamis/comet@[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
        }
      },
      "additionalProperties": false
    },
    "policy": {
      "type": "object",
      "required": ["autoTransition", "requireApplyApproval", "verifyProfile"],
      "properties": {
        "autoTransition": { "const": false },
        "requireApplyApproval": { "const": true },
        "verifyProfile": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "profile": { "const": "comet" } },
        "required": ["profile"]
      },
      "then": {
        "properties": {
          "packages": { "required": ["comet"] }
        }
      }
    }
  ],
  "additionalProperties": false
}
