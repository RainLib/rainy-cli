{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rainy.dev/schemas/verify-report.schema.json",
  "title": "Rainy Verify Report",
  "type": "object",
  "required": ["protocolVersion", "profile", "status", "steps"],
  "properties": {
    "protocolVersion": { "const": "rainy.verify.v1" },
    "profile": { "type": "string" },
    "status": { "enum": ["passed", "warning", "failed"] },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status", "message"],
        "properties": {
          "id": { "type": "string" },
          "status": { "enum": ["passed", "warning", "failed", "skipped"] },
          "message": { "type": "string" },
          "durationMs": { "type": "number" },
          "command": { "type": "string" },
          "stdout": { "type": "string" },
          "stderr": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
