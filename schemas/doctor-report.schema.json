{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rainy.dev/schemas/doctor-report.schema.json",
  "title": "Rainy Doctor Report",
  "type": "object",
  "required": ["protocolVersion", "status", "workspace", "checks"],
  "properties": {
    "protocolVersion": { "const": "rainy.doctor.v1" },
    "status": { "enum": ["passed", "warning", "failed"] },
    "workspace": { "type": "string" },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status", "message"],
        "properties": {
          "id": { "type": "string" },
          "status": { "enum": ["passed", "warning", "failed", "skipped"] },
          "message": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
