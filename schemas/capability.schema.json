{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rainy.dev/schemas/capability.schema.json",
  "title": "Rainy Capability",
  "type": "object",
  "required": ["apiVersion", "kind", "id", "name", "version", "actions"],
  "properties": {
    "apiVersion": { "const": "rainy.dev/v1" },
    "kind": { "const": "Capability" },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "dependsOn": {
      "type": "array",
      "items": { "type": "string" }
    },
    "providers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "default": { "type": "boolean" },
          "requiredConfig": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    },
    "actions": {
      "type": "object",
      "properties": {
        "install": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "uses"],
            "properties": {
              "id": { "type": "string" },
              "uses": { "type": "string" },
              "with": { "type": "object" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "properties": {
        "allowEdit": {
          "type": "array",
          "items": { "type": "string" }
        },
        "denyEdit": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requireApproval": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
