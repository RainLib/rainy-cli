{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rainy.dev/schemas/skill-lock.schema.json",
  "title": "Rainy Skill Lock",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "lockfileVersion",
    "profile",
    "scope",
    "language",
    "targets",
    "rainyVersion",
    "managedSkills",
    "upstreamSkills",
    "installedAt"
  ],
  "properties": {
    "apiVersion": { "const": "rainy.dev/v1" },
    "kind": { "const": "SkillLock" },
    "lockfileVersion": { "const": 1 },
    "profile": { "enum": ["rainy", "comet"] },
    "scope": { "const": "project" },
    "language": { "enum": ["en", "zh"] },
    "targets": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "rainyVersion": { "type": "string", "minLength": 1 },
    "comet": {
      "type": "object",
      "required": ["package", "version", "runner"],
      "properties": {
        "package": { "const": "@rpamis/comet" },
        "version": { "type": "string", "minLength": 1 },
        "runner": { "enum": ["npx", "custom"] }
      },
      "additionalProperties": false
    },
    "managedSkills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "target", "path", "digest"],
        "properties": {
          "name": { "enum": ["rainy-cli", "rainy-comet"] },
          "target": { "type": "string" },
          "path": { "type": "string", "minLength": 1 },
          "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        },
        "additionalProperties": false
      }
    },
    "upstreamSkills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "target", "paths", "managedBy", "digest"],
        "properties": {
          "name": { "enum": ["comet", "openspec", "superpowers"] },
          "target": { "type": "string" },
          "paths": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "managedBy": { "const": "comet" },
          "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        },
        "additionalProperties": false
      }
    },
    "installerOutputDigest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "installedAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
