{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rainy.dev/schemas/capability-pack.schema.json",
  "title": "Rainy Capability Pack",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "exports"],
  "properties": {
    "apiVersion": { "const": "rainy.dev/v1" },
    "kind": { "const": "CapabilityPack" },
    "metadata": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "owner": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": true
    },
    "exports": {
      "type": "object",
      "properties": {
        "capabilities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "validators": {
          "type": "array",
          "items": { "type": "string" }
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
