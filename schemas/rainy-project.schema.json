{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rainy.dev/schemas/rainy-project.schema.json",
  "title": "Rainy Project",
  "type": "object",
  "required": ["apiVersion", "kind", "project", "paths", "package"],
  "properties": {
    "apiVersion": { "const": "rainy.dev/v1" },
    "kind": { "const": "Project" },
    "project": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "type": "string" },
        "owner": { "type": "string" }
      },
      "additionalProperties": true
    },
    "paths": {
      "type": "object",
      "required": ["backend", "frontend"],
      "properties": {
        "backend": { "type": "string" },
        "frontend": { "type": "string" },
        "generated": { "type": "string" },
        "evidence": { "type": "string" }
      },
      "additionalProperties": true
    },
    "package": {
      "type": "object",
      "required": ["java"],
      "properties": {
        "java": { "type": "string" },
        "npmScope": { "type": "string" }
      },
      "additionalProperties": true
    },
    "capabilityRegistry": {
      "type": "object",
      "properties": {
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "enum": ["local", "git", "http"] },
              "path": { "type": "string" },
              "url": { "type": "string" },
              "ref": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "properties": {
        "allowEdit": {
          "type": "array",
          "items": { "type": "string" }
        },
        "denyEdit": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requireApproval": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
